<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KimmysCredentialing.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        mc:Ignorable="d"
        d:DesignWidth="1000"
        d:DesignHeight="700"
        x:Class="KimmysCredentialing.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Kimmy's Credentialing"
        Width="1000"
        Height="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20">
        <TextBlock Text="Provider Manager"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        <Border Grid.Row="1"
        BorderThickness="1"
        Padding="10"
        Margin="0,0,0,15"
        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusColor}"
                   FontSize="16"/>   
</Border>
        <Border Grid.Row="2"
        BorderBrush="DarkOrange"
        BorderThickness="1"
        Padding="12"
        Margin="0,0,0,20">
    <StackPanel Spacing="8">
        <TextBlock Text="Expiring in the Next 30 Days"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <ListBox ItemsSource="{Binding ExpiringSoonCredentials}"
                 Height="120">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding ProviderDisplayName}" FontWeight="Bold"/>
                        <TextBlock Text=" - "/>
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock Text="{Binding ExpirationDate, StringFormat='Expires: {0:d}'}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Border>
        
        

        <TabControl Grid.Row="3">
            <TabItem Header="Dashboard">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="15">
					<StackPanel Spacing="20">
						<TextBlock Text="Dashboard Summary"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
							<Border Grid.Column="0"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Padding="20">
                                <StackPanel Spacing="8">
									<TextBlock Text="Total Providers"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TotalProviders}"
                                               FontSize="28"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                             <Border Grid.Column="1"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Total Credentials"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalCredentials}"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Expiring Soon"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ExpiringSoonCount}"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                        </Grid>
                        <Button Content="Export Backup"
                                    Width="160"
                                    Margin="0,20,0,0"
                                    Click="ExportBackup_Click"/>
                    </StackPanel>
                </Border>
                </ScrollViewer>
        </TabItem>
        <TabItem Header="Providers">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="15">
                    <Grid ColumnDefinitions="2*,3*" ColumnSpacing="20">

                        <Border Grid.Column="0"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Add / Edit Provider"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Name"/>
                                <TextBox Text="{Binding Name}" Watermark="Enter provider name"/>

                                <TextBlock Text="NPI"/>
                                <TextBox Text="{Binding Npi}" Watermark="Enter NPI"/>

                                <TextBlock Text="Specialty"/>
                                <TextBox Text="{Binding Specialty}" Watermark="Enter specialty"/>

                                <TextBlock Text="Email"/>
                                <TextBox Text="{Binding Email}" Watermark="Enter email"/>

                                <TextBlock Text="Phone"/>
                                <TextBox Text="{Binding Phone}" Watermark="Enter phone"/>

                                <Button Content="Add Provider"
                                        Command="{Binding AddProviderCommand}"
                                        Width="140"
                                        Margin="0,10,0,10"/>

                                <Button Content="Update Provider"
                                        Command="{Binding UpdateProviderCommand}"
                                        Width="140"
                                        Margin="0,0,0,10"/>

                                <Button Content="Delete Selected Provider"
                                        Click="DeleteProvider_Click"
                                        Width="180"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Providers"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Search Providers"/>
                                <TextBox Text="{Binding ProviderSearchText}"
                                         Watermark="Search by name, NPI, specialty, email, or phone"/>

                                <ListBox ItemsSource="{Binding Providers}"
                                         SelectedItem="{Binding SelectedProvider}"
                                         Height="500">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="LightGray"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding NPI}"/>
                                                    <TextBlock Text="{Binding Specialty}"/>
                                                    <TextBlock Text="{Binding Email}"/>
                                                    <TextBlock Text="{Binding Phone}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Credentials">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Credentials"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedProvider.Name, FallbackValue='Select a provider from the Providers tab'}"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBlock Text="Credential Name"/>
                        <TextBox Text="{Binding CredentialName}" Watermark="Enter credential name"/>

                        <TextBlock Text="Issue Date"/>
                        <DatePicker SelectedDate="{Binding CredentialIssueDate}"/>

                        <TextBlock Text="Expiration Date"/>
                        <DatePicker SelectedDate="{Binding CredentialExpirationDate}"/>

                        <TextBlock Text="Document Path"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding CredentialFilePath}"
                                     Watermark="Enter document path or browse for file"/>

                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Click="BrowseDocument_Click"/>
                        </Grid>

                        <TextBlock Text="Notes"/>
                        <TextBox Text="{Binding CredentialNotes}"
                                 Watermark="Enter notes"
                                 AcceptsReturn="True"
                                 Height="80"/>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,10">
                            <Button Content="Add Credential"
                                    Command="{Binding AddCredentialCommand}"
                                    Width="150"/>

                            <Button Content="Update Credential"
                                    Command="{Binding UpdateCredentialCommand}"
                                    Width="150"/>

                            <Button Content="Delete Selected Credential"
                                    Click="DeleteCredential_Click"
                                    Width="190"/>

                            <Button Content="Open Document"
                                    Click="OpenDocument_Click"
                                    Width="150"/>
                        </StackPanel>

                        <TextBlock Text="Saved Credentials"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0"/>

                        <TextBlock Text="Filter by Status"/>
                        <ComboBox ItemsSource="{Binding CredentialStatusFilters}"
                                  SelectedItem="{Binding SelectedCredentialStatusFilter}"
                                  Width="180"/>

                        <ListBox ItemsSource="{Binding Credentials}"
                                 SelectedItem="{Binding SelectedCredential}"
                                 Height="350">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray"
                                            BorderThickness="0,0,0,1"
                                            Padding="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Status}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding IssueDate, StringFormat='Issue: {0:d}'}"/>
                                            <TextBlock Text="{Binding ExpirationDate, StringFormat='Expires: {0:d}'}"/>
                                            <TextBlock Text="{Binding FilePath, StringFormat='File: {0}'}"/>
                                            <TextBlock Text="{Binding Notes}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Alerts">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Expiring in the Next 30 Days"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <ListBox ItemsSource="{Binding ExpiringSoonCredentials}"
                                 Height="500">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray"
                                            BorderThickness="0,0,0,1"
                                            Padding="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding ProviderDisplayName}" FontWeight="Bold"/>
                                            <TextBlock Text=" - "/>
                                            <TextBlock Text="{Binding Name}"/>
                                            <TextBlock Text="{Binding ExpirationDate, StringFormat='Expires: {0:d}'}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Grid>


</Window>